<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
  <targets>
    <target name="file" xsi:type="File"
            fileName="${basedir}/logs/app_${shortdate}.log"
            layout="${longdate} [${level:uppercase=true:padding=-5}] ${logger} - ${message} ${exception:format=tostring}"
            encoding="utf-8"
            maxArchiveDays="90" />
    <target name="console" xsi:type="Console"
            layout="${longdate} [${level:uppercase=true:padding=-5}] ${message} ${exception:format=tostring}" />
  </targets>
  <rules>
    <logger name="*" minlevel="Info" writeTo="file" />
    <logger name="*" minlevel="Info" writeTo="console" />
  </rules>
</nlog>
